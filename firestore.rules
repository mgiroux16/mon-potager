rules_version = '2';

// Chaque utilisateur authentifie n'a acces qu'a son propre sous-arbre
// users/{uid}/** : la synchro ecrit/lit uniquement sous l'uid courant.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
